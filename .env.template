# Geopolitical Muscle ML — API Key Configuration
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ─── ACLED (Armed Conflict Location & Event Data) ───────────────────────────
# Register at: https://acleddata.com/myacled
# Auth: OAuth Bearer token — no static API key. The pipeline authenticates
# with your email + password to get a 24-hour token automatically.
# Docs: https://acleddata.com/api-documentation/getting-started
ACLED_EMAIL=your_registered_email@example.com
ACLED_PASSWORD=your_acled_password_here

# ─── GDELT ───────────────────────────────────────────────────────────────────
# Fully open — no API key required.
# gdeltPyR fetches directly from Google BigQuery or GDELT file servers.
# Optional: provide a Google Cloud service account key path if using BigQuery.
GOOGLE_APPLICATION_CREDENTIALS=  # path to service account JSON, or leave blank

# ─── SEC EDGAR ───────────────────────────────────────────────────────────────
# No API key required, but EDGAR enforces rate limits (10 req/sec max).
# Required: a User-Agent header string identifying your application.
# Format: "Company Name contact@email.com" per EDGAR fair-access policy.
EDGAR_USER_AGENT=YourName your_email@example.com
# Optional: if you have an EDGAR API key from the beta program
EDGAR_API_KEY=

# ─── Global Trade Alert ──────────────────────────────────────────────────────
# API docs: https://github.com/global-trade-alert/docs/blob/main/.api/gta-data.md
# Register for API key at: https://globaltradealert.org/api-access
# Demo key is free (core fields). Full key adds descriptions/source URLs.
GTA_API_KEY=your_gta_api_key_here

# ─── OFAC Sanctions List ──────────────────────────────────────────────────────
# Fully open — no API key required.
# SDN XML feed: https://sanctionslist.ofac.treas.gov/Home/SdnList
# EU Consolidated List: https://webgate.ec.europa.eu/fsd/fsf
OFAC_SDN_URL=https://sanctionslist.ofac.treas.gov/Home/SdnList

# ─── BIS Entity List ──────────────────────────────────────────────────────────
# Fully open — no API key required.
# CSV: https://www.bis.doc.gov/index.php/the-denied-persons-list
BIS_ENTITY_LIST_URL=https://www.bis.doc.gov/index.php/the-denied-persons-list

# ─── Financial Data (for event studies) ───────────────────────────────────────
# Yahoo Finance via yfinance: no key required, but rate-limited.
# Alpha Vantage (optional fallback): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# For prototyping, SQLite is used by default (no config needed).
# For production PostgreSQL, set these:
DB_BACKEND=sqlite   # "sqlite" or "postgres"
SQLITE_DB_PATH=data/processed/geopolitical_events.db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=geopolitical_muscle
POSTGRES_USER=
POSTGRES_PASSWORD=

# ─── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=data
